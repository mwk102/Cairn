{
  "expo": {
    "name": "Cairn",
    "slug": "cairn",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cairn",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf8f2"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#faf8f2"
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Cairn uses your location to help build a Cairn at the place you are standing."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cairn lets you attach photos to your private place journal entries.",
          "cameraPermission": "Cairn lets you capture photos for your private place journal entries."
        }
      ],
      "expo-font"
    ],
    "android": {
      "package": "com.cairn.placejournal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#faf8f2"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6bbf9735-7e5b-4fa1-9cb4-e5234d226429"
      }
    },
    "owner": "mwk102"
  }
}
